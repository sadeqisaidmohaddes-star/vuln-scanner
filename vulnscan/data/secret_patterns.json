{
  "schema_version": "1.0",
  "description": "Named secret/credential detection patterns. The secrets static module compiles these regexes, scans text files, and reports matches with the matched value REDACTED. A generic high-entropy assignment check supplements these named rules.",
  "patterns": [
    { "id": "aws-access-key-id", "name": "AWS Access Key ID", "regex": "\\b(?:AKIA|ASIA|AGPA|AIDA|AROA|ANPA|ANVA)[0-9A-Z]{16}\\b", "severity": "High", "references": ["CWE-798"], "confidence": "firm" },
    { "id": "aws-secret-key", "name": "AWS Secret Access Key", "regex": "(?i)aws_secret_access_key\\s*[:=]\\s*['\"]?[A-Za-z0-9/+=]{40}['\"]?", "severity": "Critical", "references": ["CWE-798"], "confidence": "firm" },
    { "id": "github-pat", "name": "GitHub Personal Access Token", "regex": "\\b(?:ghp|gho|ghu|ghs|ghr)_[A-Za-z0-9]{36}\\b", "severity": "Critical", "references": ["CWE-798"], "confidence": "firm" },
    { "id": "github-fine-grained-pat", "name": "GitHub Fine-grained PAT", "regex": "\\bgithub_pat_[A-Za-z0-9_]{22,255}\\b", "severity": "Critical", "references": ["CWE-798"], "confidence": "firm" },
    { "id": "google-api-key", "name": "Google API Key", "regex": "\\bAIza[0-9A-Za-z_\\-]{35}\\b", "severity": "High", "references": ["CWE-798"], "confidence": "firm" },
    { "id": "gcp-service-account", "name": "GCP Service Account Private Key", "regex": "\"private_key_id\"\\s*:\\s*\"[a-f0-9]{40}\"", "severity": "Critical", "references": ["CWE-798"], "confidence": "firm" },
    { "id": "slack-token", "name": "Slack Token", "regex": "\\bxox[baprs]-[0-9A-Za-z-]{10,72}\\b", "severity": "High", "references": ["CWE-798"], "confidence": "firm" },
    { "id": "slack-webhook", "name": "Slack Incoming Webhook", "regex": "https://hooks\\.slack\\.com/services/T[A-Za-z0-9_]+/B[A-Za-z0-9_]+/[A-Za-z0-9_]+", "severity": "Medium", "references": ["CWE-798"], "confidence": "firm" },
    { "id": "stripe-secret-key", "name": "Stripe Secret Key", "regex": "\\b(?:sk|rk)_live_[0-9A-Za-z]{24,}\\b", "severity": "Critical", "references": ["CWE-798"], "confidence": "firm" },
    { "id": "private-key-block", "name": "Private Key", "regex": "-----BEGIN (?:RSA |EC |DSA |OPENSSH |PGP )?PRIVATE KEY-----", "severity": "Critical", "references": ["CWE-321", "CWE-798"], "confidence": "firm" },
    { "id": "jwt", "name": "JSON Web Token", "regex": "\\beyJ[A-Za-z0-9_-]{10,}\\.[A-Za-z0-9_-]{10,}\\.[A-Za-z0-9_-]{10,}\\b", "severity": "Medium", "references": ["CWE-522"], "confidence": "tentative" },
    { "id": "sendgrid-key", "name": "SendGrid API Key", "regex": "\\bSG\\.[A-Za-z0-9_-]{22}\\.[A-Za-z0-9_-]{43}\\b", "severity": "High", "references": ["CWE-798"], "confidence": "firm" },
    { "id": "twilio-key", "name": "Twilio API Key", "regex": "\\bSK[0-9a-fA-F]{32}\\b", "severity": "High", "references": ["CWE-798"], "confidence": "firm" },
    { "id": "npm-token", "name": "npm Access Token", "regex": "\\bnpm_[A-Za-z0-9]{36}\\b", "severity": "High", "references": ["CWE-798"], "confidence": "firm" },
    { "id": "mailgun-key", "name": "Mailgun API Key", "regex": "\\bkey-[0-9a-zA-Z]{32}\\b", "severity": "Medium", "references": ["CWE-798"], "confidence": "tentative" },
    { "id": "telegram-bot-token", "name": "Telegram Bot Token", "regex": "\\b[0-9]{8,10}:AA[0-9A-Za-z_-]{33}\\b", "severity": "Medium", "references": ["CWE-798"], "confidence": "firm" },
    { "id": "discord-bot-token", "name": "Discord Bot Token", "regex": "\\b[MNO][A-Za-z0-9_-]{23}\\.[A-Za-z0-9_-]{6}\\.[A-Za-z0-9_-]{27}\\b", "severity": "High", "references": ["CWE-798"], "confidence": "tentative" },
    { "id": "basic-auth-url", "name": "Credentials in URL", "regex": "[a-zA-Z][a-zA-Z0-9+.-]*://[^/\\s:@]+:[^/\\s:@]+@[^/\\s]+", "severity": "High", "references": ["CWE-522"], "confidence": "tentative" },
    { "id": "generic-secret-assignment", "name": "Hardcoded secret/password assignment", "regex": "(?i)(?:password|passwd|pwd|secret|api[_-]?key|apikey|access[_-]?token|auth[_-]?token|client[_-]?secret|private[_-]?key)\\s*[:=]\\s*['\"][^'\"\\n]{8,}['\"]", "severity": "Medium", "references": ["CWE-798"], "confidence": "tentative" }
  ]
}
